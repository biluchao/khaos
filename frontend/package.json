{
  "name": "khaos-frontend",
  "version": "3.0.0",
  "private": true,
  "description": "KHAOS 机构级量化交易系统前端界面 - 支持多周期策略、自适应风控、4K中文界面，适配 2000 美金至万亿美金账户。",
  "author": "KHAOS Engineering",
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "npm@9.8.1",
  "type": "module",
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "files": [
    "dist",
    "public"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "dev": "vite --port 3000",
    "build": "NODE_OPTIONS='--max_old_space_size=4096' tsc && vite build --mode production --emptyOutDir --sourcemap hidden",
    "build:analyze": "NODE_OPTIONS='--max_old_space_size=4096' tsc && vite build --mode production --emptyOutDir --sourcemap true && source-map-explorer dist/assets/*.js",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest --globals",
    "test:coverage": "vitest --coverage",
    "test:coverage:check": "vitest --coverage --run",
    "type-check": "tsc --noEmit",
    "audit": "npm audit --audit-level=high --production",
    "audit:fix": "npm audit fix",
    "analyze": "npm run build:analyze",
    "size-check": "bundlesize",
    "prepare": "husky install || true",
    "pre-commit": "lint-staged",
    "commitlint": "commitlint --edit"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "^6.20.0",
    "@reduxjs/toolkit": "^1.9.7",
    "react-redux": "^8.1.3",
    "antd": "^5.11.0",
    "@ant-design/icons": "^5.2.6",
    "echarts": "^5.4.3",
    "echarts-for-react": "^3.0.2",
    "dayjs": "^1.11.10",
    "axios": "^1.7.0",
    "axios-retry": "^3.8.0",
    "react-error-boundary": "^4.0.11",
    "react-use-websocket": "^4.5.0",
    "react-helmet-async": "^2.0.0",
    "classnames": "^2.3.2",
    "immer": "^10.0.3",
    "klinecharts": "^4.0.0"
  },
  "optionalDependencies": {
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.5.0",
    "bufferutil": "^4.0.8",
    "utf-8-validate": "^6.0.3"
  },
  "devDependencies": {
    "@types/react": "18.2.38",
    "@types/react-dom": "18.2.17",
    "@types/node": "^20.10.0",
    "@types/axios-retry": "^3.1.3",
    "@types/react-helmet-async": "^2.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.4",
    "vite-plugin-pwa": "^0.17.4",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-visualizer": "^5.2.0",
    "typescript": "^5.3.2",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-import-helpers": "^1.3.1",
    "prettier": "^3.1.0",
    "vitest": "^0.34.6",
    "@vitest/coverage-v8": "^0.34.6",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.1.4",
    "jsdom": "^23.0.0",
    "source-map-explorer": "^2.5.3",
    "brotli-size": "^0.1.0",
    "bundlesize": "^0.18.1",
    "msw": "^2.0.0"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "@types/react": "18.2.38",
    "@types/react-dom": "18.2.17"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write --ignore-path .gitignore"
    ]
  },
  "browserslist": {
    "production": [
      "last 2 Chrome versions",
      "last 2 Firefox versions",
      "last 2 Safari versions",
      "last 2 Edge versions"
    ],
    "development": [
      "last 1 Chrome version",
      "last 1 Firefox version",
      "last 1 Safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "eslintConfig": {
    "root": true
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "bundlesize": [
    {
      "path": "./dist/assets/*.js",
      "maxSize": "500 kB"
    },
    {
      "path": "./dist/assets/*.css",
      "maxSize": "100 kB"
    }
  ]
}
